# Application
NODE_ENV=development
PORT=8080
API_PREFIX=/api

# Database
MONGODB_URI=mongodb://localhost:27017/absu

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password Reset
PASSWORD_RESET_SECRET=your_password_reset_secret_key_here
PASSWORD_RESET_EXPIRES_IN=1h

# Email (SMTP)
SMTP_SECURE=true
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here
EMAIL_FROM="ABSU Faculty System <noreply@example.com>"

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_cloudflare_access_key_id_here
R2_SECRET_ACCESS_KEY=your_cloudflare_secret_access_key_here
R2_BUCKET_NAME="absu-engineering"
R2_PUBLIC_URL=https://your_public_r2_url.r2.dev

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Default Super Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=AdminPassword123!
DEFAULT_ADMIN_NAME="Super Administrator"
